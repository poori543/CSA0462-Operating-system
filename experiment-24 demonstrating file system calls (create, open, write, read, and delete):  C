#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/stat.h>
#include <sys/types.h>

int main()
{
    int fd;
    char buffer[100];

    /* Create a new file */
    fd = creat("sample.txt", S_IRWXU);

    if (fd == -1)
    {
        perror("creat");
        exit(1);
    }
    else
    {
        printf("File 'sample.txt' created successfully.\n");
        close(fd);
    }

    /* Open file for writing */
    fd = open("sample.txt", O_WRONLY | O_APPEND);

    if (fd == -1)
    {
        perror("open");
        exit(1);
    }
    else
    {
        printf("File 'sample.txt' opened for writing.\n");
    }

    /* Write data to file */
    write(fd, "Hello, World!\n", 14);
    printf("Data written to 'sample.txt'.\n");

    close(fd);

    /* Open file for reading */
    fd = open("sample.txt", O_RDONLY);

    if (fd == -1)
    {
        perror("open");
        exit(1);
    }
    else
    {
        printf("File 'sample.txt' opened for reading.\n");
    }

    /* Read data from file */
    int bytesRead = read(fd, buffer, sizeof(buffer));

    if (bytesRead == -1)
    {
        perror("read");
        exit(1);
    }
    else
    {
        printf("Data read from 'sample.txt':\n");
        write(STDOUT_FILENO, buffer, bytesRead);
    }

    close(fd);

    /* Delete file */
    if (remove("sample.txt") == -1)
    {
        perror("remove");
        exit(1);
    }
    else
    {
        printf("\nFile 'sample.txt' deleted successfully.\n");
    }

    return 0;
}
