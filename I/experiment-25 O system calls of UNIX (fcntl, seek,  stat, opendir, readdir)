#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <errno.h>

int main()
{
    int fd;

    fd = open("foo.txt", O_RDONLY | O_CREAT, 0644);

    printf("fd = %d\n", fd);

    if (fd == -1)
    {
        printf("Error Number: %d\n", errno);
        perror("Program");
    }
    else
    {
        printf("File opened/created successfully.\n");
        close(fd);
    }

    return 0;
}
